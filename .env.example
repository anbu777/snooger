# Snooger v3.0 Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ═══════════════════════════════════════════
# AI Providers (at least one recommended)
# ═══════════════════════════════════════════

# Groq (free tier: 14,400 tokens/min) — https://console.groq.com
GROQ_API_KEY=

# DeepSeek (free tier available) — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenRouter (free models available) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ═══════════════════════════════════════════
# Out-of-band Testing
# ═══════════════════════════════════════════

INTERACTSH_URL=https://interact.sh
INTERACTSH_TOKEN=

# ═══════════════════════════════════════════
# Bug Bounty Platforms (optional)
# ═══════════════════════════════════════════

# HackerOne — https://hackerone.com/settings/api_token
HACKERONE_API_USERNAME=
HACKERONE_API_TOKEN=

# Bugcrowd — https://bugcrowd.com/account/settings
BUGCROWD_API_TOKEN=

# ═══════════════════════════════════════════
# Notifications (optional, all free)
# ═══════════════════════════════════════════

# Telegram — talk to @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord — Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Custom Webhook (any URL that accepts POST JSON)
CUSTOM_WEBHOOK_URL=

# ═══════════════════════════════════════════
# Proxy (optional)
# ═══════════════════════════════════════════

HTTP_PROXY=
HTTPS_PROXY=
